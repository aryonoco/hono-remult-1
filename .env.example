# Database connections — three roles, three URLs.
# search_path=app is in every URL so connections see the app schema
# regardless of role default (belt-and-suspenders with postgres-init's
# ALTER ROLE ... SET search_path).
#
# DATABASE_URL is the API runtime: hrm_runtime has DML rights only
# (SELECT/INSERT/UPDATE/DELETE on app.*). The Hono process must NOT be
# able to run DDL — that's enforced by the Postgres role, not by code.
DATABASE_URL=postgresql://hrm_runtime:hrm_runtime_password@postgres:5432/hono_remult_dev?sslmode=disable&search_path=app

# DATABASE_URL_MIGRATIONS is for Atlas: hrm_app owns the schema and has
# CREATE/ALTER/DROP. Only the migration pipeline (today: local atlas CLI;
# tomorrow: GitHub Actions job) ever uses this.
DATABASE_URL_MIGRATIONS=postgresql://hrm_app:hrm_dev_password@postgres:5432/hono_remult_dev?sslmode=disable&search_path=app

# ATLAS_DESIRED_URL is the scratch DB that sync-to-desired.ts populates
# with the current Remult entity schema. Atlas reads this DB as its
# "desired state" source during `atlas migrate diff`.
ATLAS_DESIRED_URL=postgresql://hrm_app:hrm_dev_password@postgres:5432/atlas_desired?sslmode=disable&search_path=app

# ATLAS_DEV_URL is Atlas's replay scratch — it wipes and rebuilds this
# DB to compute "current" schema state by replaying the migrations
# directory. Never store data here.
ATLAS_DEV_URL=postgresql://hrm_app:hrm_dev_password@postgres:5432/atlas_dev?sslmode=disable&search_path=app

# Hono API server
PORT=3000
NODE_ENV=development

# Angular dev server
NG_DEV_PORT=4200

# Dev auth — must match an id from libs/shared/domain/src/auth/dev-users.ts:
#   dev-admin | dev-user | dev-viewer
DEV_USER=dev-admin
