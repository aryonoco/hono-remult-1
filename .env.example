# Database connection — matches the docker-compose postgres service
DATABASE_URL=postgresql://hrm_app:hrm_dev_password@postgres:5432/hono_remult_dev

# Hono API server
PORT=3000
NODE_ENV=development

# Angular dev server
NG_DEV_PORT=4200

# Dev auth — must match an id from libs/shared/domain/src/auth/dev-users.ts:
#   dev-admin | dev-user | dev-viewer
DEV_USER=dev-admin
