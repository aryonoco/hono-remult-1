{
  "meta": {
    "description": "Fire-season model FY2018-FY2029. statewide = target FireIncident count for the year (realistic DEECA/FFMVic/CFA totals), apportioned by districtShareWeights; severity in [0,1] fattens the size tail and drives escalation; clusters are real (FY2018-2026) or analogue (FY2027-2029) megafires placed in their districts and date windows. FY2027/28/29 mirror the character of FY2018/19/20 with a deterministic +/-15% statewide jitter (applied in seasons.ts) so recent years stay plausible without being copies. There is no fixed anchor: the reference 'now' is injected at seed time (the real wall-clock in production, a pinned date in tests). Historical report dates are sampled inside each financial year (clamped to dataHorizon); the rolling-active overlay is anchored to the injected now. Dates are UTC.",
    "derivedFrom": {
      "2027": 2018,
      "2028": 2019,
      "2029": 2020
    },
    "statewideJitterFraction": 0.15
  },
  "dataHorizon": "2030-06-30",
  "rollingActive": {
    "description": "The deterministic, seasonally-scaled set of genuinely-active fires generated around the injected 'now'. peakCount is the active count at the busiest month; the actual count scales by that month's share of the peak monthWeight (summer-heavy), floored at 4 so even deep winter shows one fire in each interim status (going/contained/underControl). ageDaysMax bounds how long ago an active fire ignited; overdueShare is the fixed minority (round(count*share)) whose nextReportDue already passed, so overdue stays the exception at any season's size.",
    "peakCount": 60,
    "floorCount": 4,
    "ageDaysMin": 0,
    "ageDaysMax": 18,
    "overdueShare": 0.2,
    "overdueLagHoursMin": 1,
    "overdueLagHoursMax": 30,
    "upcomingLeadHoursMin": 2,
    "upcomingLeadHoursMax": 96
  },
