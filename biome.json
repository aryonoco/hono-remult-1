{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": {
    "includes": ["**", "!**/dist", "!**/out-tsc", "!**/*.html", "!.claude/workflows"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "a11y": "error",
      "complexity": "error",
      "correctness": "error",
      "nursery": {
        "useExplicitType": "error",
        "noUselessReturn": "error"
      },
      "performance": "error",
      "security": {
        "recommended": true,
        "noSecrets": "error"
      },
      "style": {
        "recommended": true,
        "noMagicNumbers": "error",
        "useNamingConvention": "error",
        "useExportsLast": "error"
      },
      "suspicious": "error"
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    },
    "formatter": {
      "enabled": true,
      "quoteStyle": "single"
    },
    "linter": { "enabled": true }
  },
  "json": {
    "formatter": { "enabled": true }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": [".vscode/*.json", "**/tsconfig*.json", "**/*.code-workspace"],
      "json": {
        "parser": {
          "allowComments": true,
          "allowTrailingCommas": true
        }
      }
    },
    {
      "includes": ["libs/shared/*/src/index.ts"],
      "linter": {
        "rules": {
          "performance": {
            "noBarrelFile": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/api/**/*.ts"],
      "javascript": {
        "globals": ["Bun"]
      }
    },
    {
      "includes": ["*.config.mjs", "**/vitest.config.ts"],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.spec.ts"],
      "javascript": {
        "globals": [
          "Bun",
          "describe",
          "it",
          "expect",
          "beforeEach",
          "afterEach",
          "beforeAll",
          "afterAll",
          "vi"
        ]
      },
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveLinesPerFunction": "off"
          },
          "nursery": {
            "useExplicitType": "off"
          },
          "suspicious": {
            "noExplicitAny": "off"
          },
          "style": {
            "noNonNullAssertion": "off",
            "noMagicNumbers": "off"
          }
        }
      }
    }
  ]
}
