{
  "name": "@workspace/source",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "libs/shared/*"
  ],
  "scripts": {
    "lint": "biome lint . && nx run-many -t lint",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check --write .",
    "check:ci": "biome ci . && nx run-many -t lint && bun run typecheck",
    "typecheck": "tsc -b --noEmit",
    "test": "nx run-many -t test",
    "format:html": "prettier --write \"**/*.html\"",
    "format:html:check": "prettier --check \"**/*.html\"",
    "migrate:generate": "bun apps/api/src/db/migrate-generate.ts",
    "migrate:plan": "atlas migrate apply --env local --dry-run",
    "migrate:apply": "atlas migrate apply --env local",
    "migrate:lint": "atlas migrate lint --env local --latest 1",
    "migrate:status": "atlas migrate status --env local",
    "migrate:validate": "atlas migrate validate --env local",
    "migrate:hash": "atlas migrate hash --env local",
    "schema:inspect": "atlas schema inspect --env local --format '{{ sql . }}'"
  },
  "dependencies": {
    "@angular/animations": "21.2.15",
    "@angular/cdk": "21.2.13",
    "@angular/common": "21.2.15",
    "@angular/compiler": "21.2.15",
    "@angular/core": "21.2.15",
    "@angular/forms": "21.2.15",
    "@angular/material": "21.2.13",
    "@angular/platform-browser": "21.2.15",
    "@angular/router": "21.2.15",
    "hono": "4.12.23",
    "neverthrow": "8.2.0",
    "pg": "8.21.0",
    "remult": "3.3.10",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/core": "21.2.13",
    "@angular/build": "21.2.13",
    "@angular/cli": "21.2.13",
    "@angular/compiler-cli": "21.2.15",
    "@biomejs/biome": "2.4.16",
    "@bufferings/eslint-plugin-neverthrow": "0.3.0",
    "@nx/angular": "22.7.5",
    "@nx/eslint": "22.7.5",
    "@nx/eslint-plugin": "22.7.5",
    "@tailwindcss/postcss": "4.3.0",
    "@types/bun": "1.3.14",
    "@types/pg": "8.20.0",
    "@typescript-eslint/parser": "8.60.0",
    "axe-core": "^4.11.4",
    "eslint": "9.39.4",
    "jsdom": "29.1.1",
    "nx": "22.7.5",
    "postcss": "8.5.15",
    "prettier": "3.8.3",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.0",
    "vitest": "4.1.7"
  }
}
